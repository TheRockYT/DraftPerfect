---
import EssayAssistant from '../components/EssayAssistant.svelte';
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <section class="mx-auto max-w-6xl px-4 pb-8 pt-12 sm:px-6 sm:pt-16 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <p
                    class="mb-4 inline-flex items-center rounded-full border border-accent/20 bg-accent-muted px-3 py-1 text-xs font-medium text-accent"
            >
                University Application Toolkit
            </p>
            <h1
                    class="text-balance text-4xl font-bold tracking-tight text-text sm:text-5xl"
            >
                Write your best <br/>
                <span class="text-accent">application essays</span>
            </h1>
            <p class="mt-4 text-balance text-lg text-text-muted">
                A distraction-free editor with real-time byte counting and automatic
                local saves. Your drafts never leave your browser.
            </p>
        </div>
    </section>

    <section
            id="editor"
            class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8"
            aria-label="Essay editor"
    >
        <EssayAssistant client:load/>
    </section>
</Layout>
